{
  "additionalProperties": false,
  "description": "Summary of one stage's execution — written into the run log and into\n``DocumentMeta.stage_reports``. Returned by every stage function.",
  "properties": {
    "counts": {
      "additionalProperties": {
        "type": "integer"
      },
      "description": "Stage-specific counters — e.g. {'chunks_emitted': 1247, 'continuations_merged': 18}. Free-form.",
      "title": "Counts",
      "type": "object"
    },
    "duration_seconds": {
      "description": "Wall-clock duration.",
      "minimum": 0,
      "title": "Duration Seconds",
      "type": "number"
    },
    "errors": {
      "description": "Fatal errors. Non-empty implies ok=False.",
      "items": {
        "type": "string"
      },
      "title": "Errors",
      "type": "array"
    },
    "finished_at": {
      "description": "UTC finish timestamp.",
      "format": "date-time",
      "title": "Finished At",
      "type": "string"
    },
    "ok": {
      "description": "Whether the stage completed without errors.",
      "title": "Ok",
      "type": "boolean"
    },
    "stage": {
      "description": "Stage name, e.g. 'chunk' or 'resolve_references'.",
      "title": "Stage",
      "type": "string"
    },
    "started_at": {
      "description": "UTC start timestamp.",
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "warnings": {
      "description": "Non-fatal anomalies the stage flagged for human review.",
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "stage",
    "started_at",
    "finished_at",
    "duration_seconds",
    "ok"
  ],
  "title": "StageReport",
  "type": "object"
}
